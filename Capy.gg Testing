    walkflingEnabled = false
    flyflingEnabled = false
    antiflingEnabled = false
    flingAllEnabled = false
    grabPlayerEnabled = false
    loopBringAllEnabled = false
    pcall(cleanupFlingAll)
    pcall(releaseGrabbedPlayer)
    
    -- Restore core defaults
    pcall(function()
        local hum = getHumanoid(LocalPlayer)
        if hum then 
            hum.PlatformStand = false 
            hum.Sit = false
            hum.AutoRotate = true
        end
        local char = LocalPlayer.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.Transparency = 0 end
            end
        end
    end)
    
    -- Clean visuals & effects
    pcall(cleanupVisuals)
    
    -- Restore hitboxes
    pcall(updateHitboxes)
    
    -- Destroy flight instances
    if flyGyro then pcall(function() flyGyro:Destroy() end); flyGyro = nil end
    if flyVelocity then pcall(function() flyVelocity:Destroy() end); flyVelocity = nil end
    if flingBodyAV then pcall(function() flingBodyAV:Destroy() end); flingBodyAV = nil end
    if waterWalkBP then pcall(function() waterWalkBP:Destroy() end); waterWalkBP = nil end
    
    -- Destroy visual GUIs
    local parent = getGuiParent()
    local main = parent and parent:FindFirstChild("CapyggUI")
    local notifs = parent and parent:FindFirstChild("CapyNotifications")
    if main then pcall(function() main:Destroy() end) end
    if notifs then pcall(function() notifs:Destroy() end) end
    local overlayGui = parent and parent:FindFirstChild("CapyOverlay")
    if overlayGui then overlayGui:Destroy() end
    for _, p in ipairs(Players:GetPlayers()) do
        if getCharacter(p) then
            local g = getCharacter(p):FindFirstChild("CapyGlow"); if g then g:Destroy() end
        end
    end
    
    debugLog("Universal Admin uninstalled successfully.")
end

