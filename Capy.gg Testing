-- Visual ESP systems
local function attachEspToPlayer(p)
    if not p or p == LocalPlayer or not espEnabled then return end
    if espTeamCheck and LocalPlayer.Team and p.Team and LocalPlayer.Team == p.Team then return end
    local char = p.Character
    local head = char and char:WaitForChild("Head", 5)
    if not head then return end
    
    local existing = espMap[p]
    if existing then
        pcall(function() existing:Destroy() end)
        espMap[p] = nil
    end
    
    local bb = Instance.new("BillboardGui")
    bb.Name = "CapyESP"
    bb.Adornee = head
    bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0, 180, 0, 44)
    bb.StudsOffset = Vector3.new(0, 2.5, 0)
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 12
    lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
    lbl.TextStrokeTransparency = 0.35
    lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    lbl.Text = p.DisplayName or p.Name
    lbl.Parent = bb
    
    bb.Parent = head
    espMap[p] = bb
end

local function updateEsp()
    local localRoot = getRootPart(LocalPlayer)
    for p, bb in pairs(espMap) do
        if bb and bb.Parent and p.Character then
            local root = getRootPart(p)
            local hum = getHumanoid(p)
            if root and localRoot and hum then
                local dist = math.round((root.Position - localRoot.Position).Magnitude)
                local hp = math.round(hum.Health)
                local maxHp = math.round(hum.MaxHealth)
                local hpPct = maxHp > 0 and math.round((hp / maxHp) * 100) or 0
                
                local lbl = bb:FindFirstChildOfClass("TextLabel")
                if lbl then
                    lbl.Text = string.format("%s\n[%s studs] [%s%% HP]", p.DisplayName or p.Name, dist, hpPct)
                    if hpPct > 50 then
                        lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
                    elseif hpPct > 20 then
                        lbl.TextColor3 = Color3.fromRGB(251, 191, 36)
                    else
                        lbl.TextColor3 = Color3.fromRGB(239, 68, 68)
                    end
                end
            end
        else
            espMap[p] = nil
        end
    end
end

local function toggleEsp(e)
    espEnabled = e
    if e then
        for _, p in ipairs(Players:GetPlayers()) do
            attachEspToPlayer(p)
        end
    else
        for p, bb in pairs(espMap) do
            if bb and bb.Parent then pcall(function() bb:Destroy() end) end
        end
        espMap = {}
    end
end

