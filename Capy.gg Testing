-- Custom IY-like Flight System (Anchors and uses stabilize Gyro/Velocity)
local function enableFly(e)
    if not LocalPlayer then return end
    local r = getRootPart(LocalPlayer)
    local hum = getHumanoid(LocalPlayer)
    flyEnabled = e
    
    if flyGyro then pcall(function() flyGyro:Destroy() end); flyGyro = nil end
    if flyVelocity then pcall(function() flyVelocity:Destroy() end); flyVelocity = nil end
    if hum then hum.PlatformStand = e end
    
    if not e or not r then return end
    
    -- Stabilizer Gyro
    flyGyro = Instance.new("BodyGyro")
    flyGyro.Name = "CapyFlyGyro"
    flyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    flyGyro.CFrame = r.CFrame
    flyGyro.Parent = r
    
    -- Velocity Mover
    flyVelocity = Instance.new("BodyVelocity")
    flyVelocity.Name = "CapyFlyVel"
    flyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    flyVelocity.Velocity = Vector3.new(0, 0, 0)
    flyVelocity.Parent = r
end

local function updateFly()
    if not flyEnabled or not flyVelocity or not flyGyro or not UserInputService then return end
    local camera = Workspace and Workspace.CurrentCamera
    local r = getRootPart(LocalPlayer)
    if not camera or not r then return end
    
    local look = camera.CFrame.LookVector
    local right = camera.CFrame.RightVector
    local d = Vector3.new(0, 0, 0)
    
    -- Movement calculation
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then d = d + look end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then d = d - look end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then d = d - right end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then d = d + right end
    
    -- Rise/Descend (E & Q standard flight keys)
    if UserInputService:IsKeyDown(Enum.KeyCode.E) then d = d + Vector3.new(0, 1, 0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.Q) then d = d - Vector3.new(0, 1, 0) end
    
    if d.Magnitude > 0 then
        flyVelocity.Velocity = d.Unit * flySpeed
    else
        flyVelocity.Velocity = Vector3.new(0, 0, 0)
    end
    
    flyGyro.CFrame = camera.CFrame
end

