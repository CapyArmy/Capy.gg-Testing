-- Draggable handler (Click anywhere on the window/empty area to drag)
local function makeDraggable(frame)
    local dragStart, startPos
    
    frame.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragStart = input.Position
            startPos = frame.Position
            
            local dragConnection
            dragConnection = UserInputService.InputChanged:Connect(function(changedInput)
                if changedInput.UserInputType == Enum.UserInputType.MouseMovement or changedInput.UserInputType == Enum.UserInputType.Touch then
                    local delta = Vector2.new(changedInput.Position.X - dragStart.X, changedInput.Position.Y - dragStart.Y)
                    frame.Position = UDim2.new(
                        startPos.X.Scale, startPos.X.Offset + delta.X,
                        startPos.Y.Scale, startPos.Y.Offset + delta.Y
                    )
                end
            end)
            
            local dragEndedConnection
            dragEndedConnection = UserInputService.InputEnded:Connect(function(endedInput)
                if endedInput.UserInputType == Enum.UserInputType.MouseButton1 or endedInput.UserInputType == Enum.UserInputType.Touch then
                    dragConnection:Disconnect()
                    dragEndedConnection:Disconnect()
                end
            end)
        end
    end)
end

