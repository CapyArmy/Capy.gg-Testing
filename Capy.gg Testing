local function loadInfiniteYield()
    local src = safeHttpGet("https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source")
    if not src then
        notify("Capy.gg", "Failed to fetch Infinite Yield.", 4)
        return
    end
    local loader = loadstring or load
    if type(loader) ~= "function" then
        notify("Capy.gg", "No loadstring capability available.", 3)
        return
    end
    local okCompile, compiled = pcall(function() return loader(src) end)
    if not okCompile or type(compiled) ~= "function" then
        notify("Capy.gg", "Compilation failed.", 3)
        return
    end
    local ok = pcall(compiled)
    notify("Capy.gg", ok and "Infinite Yield loaded." or "Failed to run IY", 3)
end

local function giveBtools()
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    if not backpack then return end
    
    local toolNames = {"CloneBin", "Destructor", "Grabber"}
    for _, name in ipairs(toolNames) do
        local t = Instance.new("Tool")
        t.Name = name
        t.RequiresHandle = false
        t.Parent = backpack
        
        t.Activated:Connect(function()
            local mouse = LocalPlayer:GetMouse()
            local target = mouse.Target
            if target and not target:IsA("Terrain") then
                if name == "Destructor" then
                    pcall(function() target:Destroy() end)
                elseif name == "CloneBin" then
                    pcall(function()
                        local c = target:Clone()
                        c.Parent = target.Parent
                        c.Position = c.Position + Vector3.new(0, target.Size.Y, 0)
                    end)
                elseif name == "Grabber" then
                    pcall(function()
                        target.Anchored = false
                    end)
                end
            end
        end)
    end
    notify("Utilities", "Classic Building Tools loaded in Backpack!", 3)
end

