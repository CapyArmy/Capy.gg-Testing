    end)
    pcall(function()
        for _, p in ipairs(Players:GetPlayers()) do
            local h = getHumanoid(p)
            if h then
                h.AutoRotate = false
                h.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
            end
