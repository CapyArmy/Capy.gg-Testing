-- Aimbot Target Resolver (Screen-distance based)
local function getAimbotTarget()
    local closest, dist = nil, math.huge
    local r = getRootPart(LocalPlayer)
    local camera = Workspace.CurrentCamera
    if not r or not camera then return nil end
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local part = aimHitPart == "Random" and p.Character:FindFirstChildWhichIsA("BasePart") or p.Character:FindFirstChild(aimHitPart)
            if not part then part = p.Character:FindFirstChild("Head") or p.Character:FindFirstChildWhichIsA("BasePart") end
            local hum = getHumanoid(p)
            if part and hum and hum.Health > 0 then
                local pos, onScreen = camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mousePos = getMouseLocation()
                    local screenDist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if screenDist < dist then
                        dist = screenDist
                        closest = p
                    end
                end
            end
        end
    end
    return closest
end

-- Combat Commands
local function killAllHumanoids()
    if not Workspace or not LocalPlayer then return end
    local char = LocalPlayer.Character
    local count = 0
    for _, o in ipairs(Workspace:GetDescendants()) do
        if o:IsA("Humanoid") and o.Parent ~= char then
            pcall(function() o.Health = 0 end)
            local targetChar = o.Parent
            if targetChar then
                for _, d in ipairs(targetChar:GetDescendants()) do
                    if d:IsA("RemoteEvent") or d:IsA("RemoteFunction") then
                        local name = d.Name:lower()
                        if name:find("damage") or name:find("hit") or name:find("take") or name:find("bullet") or name:find("melee") or name:find("attack") then
                            pcall(function() d:FireServer(9e9, targetChar:GetPivot().Position) end)
                        end
                    end
                end
            end
            count = count + 1
        end
    end
    notify("Trolling", "Kill All executed. Targets hit: " .. tostring(count), 3)
end

