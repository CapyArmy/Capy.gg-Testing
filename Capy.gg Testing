        local mp = (input.UserInputType == Enum.UserInputType.Touch and input.Position) or UserInputService:GetMouseLocation()
        if not mp then return end
        local wa = win.AbsolutePosition
        if not wa then return end
        local bSize = IS_MOBILE and 32 or 26
        for _, e in ipairs(capyBtnList) do
            if e.btn and e.btn.Visible then
                local bx = wa.X + 560 + e.xOff
                local by = wa.Y + 6
                if mp.X >= bx and mp.X <= bx + bSize and mp.Y >= by and mp.Y <= by + bSize then
                    e.btn.BackgroundColor3 = Color3.new(1, 1, 1)
