-- Triggerbot loop (fires clicks while hovering an enemy, stops when not hovering)
local triggerbotClicking = false
task.spawn(function()
    while true do
        task.wait(0.05)
        if triggerbotEnabled then
            local shouldClick = false
            pcall(function()
                local cam = Workspace and Workspace.CurrentCamera
                if not cam then return end
                local ray = cam:ViewportPointToRay(0.5, 0.5)
                local hit
                local ok = pcall(function()
                    local params = RaycastParams.new(); params.FilterType = Enum.RaycastFilterType.Blacklist
                    local result = Workspace:Raycast(ray.Origin, ray.Direction * 1000, params)
                    if result then hit = result.Instance end
                end)
                if not ok then
                    hit = Workspace:FindPartOnRay(Ray.new(ray.Origin, ray.Direction * 1000))
                end
                if hit and hit.Parent then
                    local h = hit.Parent:FindFirstChildOfClass("Humanoid")
                    if h and type(h.Health) == "number" and h.Health > 0 and hit.Parent ~= getCharacter(LocalPlayer) then
                        shouldClick = true
                    end
                end
            end)
            if shouldClick then
                local vim = game:GetService("VirtualInputManager")
                vim:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                task.wait(0.02)
                vim:SendMouseButtonEvent(0, 0, 0, false, game, 0)
            end
        end
    end
end)

