-- Universal task library compatibility shim for all executors
-- Falls back: task library -> wait/spawn/delay globals -> coroutines
local task = (function()
    local ok, t = pcall(function()
        local base = _G.task
        if type(base) ~= "table" then base = {} end
        if type(base.wait) ~= "function" then
            base.wait = (type(wait) == "function") and function(...) return wait(...) end or function() end
        end
        if type(base.spawn) ~= "function" then
            if type(spawn) == "function" then
                base.spawn = function(f, ...)
                    if type(f) ~= "function" then return end
                    local args = {...}
                    spawn(function() pcall(f, unpack(args)) end)
                end
            else
                base.spawn = function(f, ...)
                    if type(f) ~= "function" then return end
                    local args = {...}
                    local co = coroutine.create(function() pcall(f, unpack(args)) end)
                    coroutine.resume(co)
                    return co
                end
            end
        end
        if type(base.delay) ~= "function" then
            if type(delay) == "function" then
                base.delay = function(n, f) delay(n, function() pcall(f) end) end
            else
                base.delay = function(n, f) base.spawn(function() base.wait(n); pcall(f) end) end
            end
        end
        if type(base.defer) ~= "function" then
            base.defer = function(f, ...) base.spawn(f, ...) end
        end
        return base
    end)
    if ok and type(t) == "table" then return t end
    -- Absolute last-resort fallback
    local fb = {}
    fb.wait = (type(wait) == "function") and function(t) return wait(t) end or function() end
    fb.spawn = (type(spawn) == "function") and function(f, ...) local a = {...}; spawn(function() pcall(f, unpack(a)) end) end or function() end
    fb.delay = (type(delay) == "function") and function(n, f) delay(n, f) end or function() end
    fb.defer = function(f, ...) fb.spawn(f, ...) end
    return fb
end)()

