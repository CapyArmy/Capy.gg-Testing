local function killTarget()
    if not LocalPlayer then return end
    local m = LocalPlayer:GetMouse()
    local h = m.Target and m.Target.Parent and m.Target.Parent:FindFirstChildOfClass("Humanoid")
    if h and h.Health > 0 and m.Target.Parent ~= LocalPlayer.Character then
        pcall(function() h.Health = 0 end)
        notify("Trolling", "Target " .. tostring(m.Target.Parent.Name) .. " eliminated.", 2)
    else
        notify("Trolling", "Hover cursor over a target to kill.", 3)
    end
end

local function getClosestPlayer()
    if not Players or not LocalPlayer then return nil end
    local closest, dist = nil, math.huge
    local r = getRootPart(LocalPlayer)
    if not r then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local pr = getRootPart(p)
            if pr then
                local d = (r.Position - pr.Position).Magnitude
                if d < dist then dist = d; closest = p end
            end
        end
    end
    return closest
end

local function teleportToPlayer(n)
    if not Players or not LocalPlayer then return end
    local t = Players:FindFirstChild(n)
    if not t then notify("Teleport", "Player not found", 3); return end
    local tr, lr = getRootPart(t), getRootPart(LocalPlayer)
    if tr and lr then
        lr.CFrame = tr.CFrame + Vector3.new(0, 5, 0)
        notify("Teleport", "Teleported to " .. n, 2)
    end
end

local function teleportToRandom()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and getRootPart(p) then
            table.insert(list, p)
        end
    end
    if #list > 0 then
        local target = list[math.random(1, #list)]
        teleportToPlayer(target.Name)
    else
        notify("Teleport", "No other players found.", 3)
    end
end

local function teleportToSpawn()
    local spawn = Workspace:FindFirstChildOfClass("SpawnLocation")
