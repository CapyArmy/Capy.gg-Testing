        btn.TextSize = 11
        btn.TextColor3 = C.accent
        btn.Text = currentVal
        btn.Parent = f
        corner(btn, 6)
        stroke(btn, C.border, 1)
        
        local dropFrame = Instance.new("Frame")
        dropFrame.Size = UDim2.new(0, 100, 0, #options * 28 + 4)
        dropFrame.Visible = false
        dropFrame.BackgroundColor3 = C.surface2
        dropFrame.BorderSizePixel = 0
        dropFrame.ZIndex = 100
        dropFrame.Parent = win
        corner(dropFrame, 6)
        stroke(dropFrame, C.border, 1)
        
        local list = Instance.new("UIListLayout")
        list.Padding = UDim.new(0, 2)
        list.Parent = dropFrame
        
        local pad = Instance.new("UIPadding")
        pad.PaddingTop = UDim.new(0, 2)
        pad.PaddingLeft = UDim.new(0, 2)
        pad.PaddingRight = UDim.new(0, 2)
        pad.Parent = dropFrame
        
        for _, opt in ipairs(options) do
            local ob = Instance.new("TextButton")
            ob.Size = UDim2.new(1, 0, 0, 24)
            ob.BackgroundColor3 = C.surface
            ob.BorderSizePixel = 0
            ob.AutoButtonColor = false
            ob.Font = Enum.Font.Gotham
            ob.TextSize = 11
            ob.TextColor3 = C.text
            ob.Text = opt
            ob.ZIndex = 101
            ob.Parent = dropFrame
            corner(ob, 4)
            
            ob.MouseButton1Click:Connect(function()
                currentVal = opt
                btn.Text = opt
                dropFrame.Visible = false
                pcall(cb, opt)
            end)
            
            ob.MouseEnter:Connect(function()
                ob.BackgroundColor3 = C.accentH
            end)
            ob.MouseLeave:Connect(function()
                ob.BackgroundColor3 = C.surface
            end)
        end
        
        btn.MouseButton1Click:Connect(function()
            dropFrame.Visible = not dropFrame.Visible
            if dropFrame.Visible then
                local absPos = btn.AbsolutePosition
                local winPos = win.AbsolutePosition
                dropFrame.Position = UDim2.new(0, absPos.X - winPos.X - 10, 0, absPos.Y - winPos.Y + 26)
            end
        end)
        
        UserInputService.InputBegan:Connect(function(input, proc)
            if proc then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                task.wait()
                local obj = input.Target
                local inDropdown = false
                local function check(p)
                    if not p then return end
                    if p == dropFrame or p == btn then inDropdown = true; return end
                    check(p.Parent)
                end
                check(obj)
                if not inDropdown then
                    dropFrame.Visible = false
                end
            end
        end)
    end
    
    local function addSlider(tab, txt, defaultVal, minVal, maxVal, cb)
        local f = Instance.new("Frame")
        f.Size = UDim2.new(1, 0, 0, 38)
        f.BackgroundColor3 = C.surface
        f.BorderSizePixel = 0
        f.Parent = tabContents[tab]
        corner(f, 8)
        stroke(f, C.border, 1)
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0, 100, 1, 0)
        label.Position = UDim2.new(0, 12, 0, 0)
        label.BackgroundTransparency = 1
        label.Font = Enum.Font.GothamMedium
        label.TextSize = 12
        label.TextColor3 = C.text
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Text = txt
        label.Parent = f
        
        local valLabel = Instance.new("TextLabel")
        valLabel.Size = UDim2.new(0, 36, 0, 18)
        valLabel.Position = UDim2.new(1, -42, 0.5, -9)
        valLabel.BackgroundColor3 = C.bg
        valLabel.BorderSizePixel = 0
        valLabel.Font = Enum.Font.Gotham
        valLabel.TextSize = 11
        valLabel.TextColor3 = C.accent
        valLabel.Text = tostring(defaultVal)
        valLabel.Parent = f
        corner(valLabel, 4)
        stroke(valLabel, C.border, 1)
        
        local track = Instance.new("Frame")
        track.Size = UDim2.new(0, 100, 0, 6)
        track.Position = UDim2.new(0, 115, 0.5, -3)
        track.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        track.BorderSizePixel = 0
        track.Parent = f
        corner(track, 3)
        
        local fill = Instance.new("Frame")
        fill.BackgroundColor3 = Color3.fromRGB(34, 197, 94)
        fill.BorderSizePixel = 0
        fill.Parent = track
        corner(fill, 3)
        
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 14, 0, 14)
        btn.BackgroundColor3 = Color3.fromRGB(50, 220, 110)
        btn.Text = ""
        btn.AutoButtonColor = false
        btn.Parent = f
        corner(btn, 7)
        stroke(btn, Color3.fromRGB(25, 150, 70), 1)
        
        local currentVal = defaultVal
        
        local function updateSlider(val)
            local pct = (val - minVal) / (maxVal - minVal)
            fill.Size = UDim2.new(pct, 0, 1, 0)
            btn.Position = UDim2.new(pct, -7, 0.5, -7)
            valLabel.Text = tostring(math.floor(val))
            currentVal = val
            pcall(cb, val)
        end
        
        local function setFromMouse(mousePos)
            local absPos = track.AbsolutePosition
            local absSize = track.AbsoluteSize
            local relX = mousePos.X - absPos.X
            local pct = clamp(relX / absSize.X, 0, 1)
            local val = math.floor(minVal + pct * (maxVal - minVal))
            if val ~= currentVal then updateSlider(val) end
        end
        
        btn.MouseButton1Down:Connect(function()
            sliderDragging = true
            sliderUpdateFunc = function(pos)
                local absPos = track.AbsolutePosition
                local absSize = track.AbsoluteSize
                local relX = pos.X - absPos.X
                local pct = clamp(relX / absSize.X, 0, 1)
                local val = math.floor(minVal + pct * (maxVal - minVal))
                if val ~= currentVal then updateSlider(val) end
            end
        end)
        
        track.MouseButton1Click:Connect(function()
            setFromMouse(getMouseLocation())
        end)
        
        updateSlider(defaultVal)
    end
    
