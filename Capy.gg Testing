local function serverHopEmpty()
    local http = game:GetService("HttpService")
    local api = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    notify("Server Hop", "Searching for empty servers...", 3)
    
    local ok, res = pcall(function()
        local data = safeHttpGet(api)
        if data then
            local json = http:JSONDecode(data)
            if json and json.data then
                for _, s in ipairs(json.data) do
                    if s.playing and s.playing < s.maxPlayers and s.id ~= game.JobId then
                        TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id, LocalPlayer)
                        return
                    end
                end
            end
        end
    end)
    if not ok then serverHop() end
end

