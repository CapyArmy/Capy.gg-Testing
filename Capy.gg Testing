            listening = true
            btn.BackgroundColor3 = Color3.fromRGB(220, 80, 80)
            btn.Text = "..."
            local oldC = btn.BackgroundColor3
            con = UserInputService.InputBegan:Connect(function(input, proc)
                if proc then return end
                if input.KeyCode ~= Enum.KeyCode.Unknown then
                    listening = false
                    con:Disconnect()
                    btn.BackgroundColor3 = C.bg
                    btn.Text = input.KeyCode.Name
                    minimizeKey = input.KeyCode
                    pcall(cb, input.KeyCode)
                end
            end)
        end)
        
        btn.MouseEnter:Connect(function()
            if not listening then
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = C.accentH}):Play()
            end
        end)
        btn.MouseLeave:Connect(function()
