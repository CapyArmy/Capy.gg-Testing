-- Physics loop connections
connections["Stepped"] = RunService.Stepped:Connect(function()
    pcall(function()
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        -- Infinite Camera Zoom
        local cam = Workspace and Workspace.CurrentCamera
        if cam and infiniteZoomEnabled then
            cam.MaxZoomDistance = 99999
        end
        
        -- Enforce WalkSpeed
        if walkspeedEnabled and hum then
            hum.WalkSpeed = targetWalkspeed
        end
        
        -- Enforce JumpPower
        if jumppowerEnabled and hum then
            hum.JumpPower = targetJumppower
            hum.UseJumpPower = true
        end
        
        -- Flight
        if flyEnabled and flyVelocity and flyGyro and root then
            updateFly()
        end
        
        -- Spinbot
        if spinbotEnabled and root then
            root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(spinSpeed), 0)
        end
        
        -- Hitbox Expander loop override
        if hitboxesExpanded then
            updateHitboxes()
        end
        
        -- Car Speed Boost
        if carSpeedEnabled and hum and hum.SeatPart and hum.SeatPart:IsA("VehicleSeat") then
            local seat = hum.SeatPart
            seat.MaxSpeed = carSpeedValue
            if seat.Throttle > 0 then
                seat.Velocity = seat.CFrame.LookVector * carSpeedValue
            end
        end
        
        -- Anti-Sit (skip for 1.5s after respawn)
        if antiSitEnabled and hum then
            if now() - (lastSpawnTime or 0) > 1.5 then
                hum.Sit = false
            end
        end
        
        -- Anti-Freeze (skip for 1s after respawn to let game finish spawning)
        if antiFreezeEnabled and not flyEnabled and char then
            local elapsed = now() - (lastSpawnTime or 0)
            if elapsed > 1 then
                for _, part in ipairs(char:GetChildren()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" and part.Anchored then
                        part.Anchored = false
                    end
                end
            end
        end
        
        -- Anti-Ragdoll (skip for 1s after respawn)
        if antiRagdollEnabled and char then
            local elapsed = now() - (lastSpawnTime or 0)
            if elapsed > 1 then
                for _, joint in ipairs(char:GetDescendants()) do
                    if joint:IsA("HingeConstraint") or joint:IsA("BallSocketConstraint") then
                        joint.Enabled = false
                    end
                end
            end
        end
        
        -- God Mode (every way)
        if godModeEnabled then
            applyGodMode()
        end
        
        -- No Recoil / No Spread (server-side simulation doesn't apply, but we disable client effects)
        if noRecoilEnabled and char then
            for _, v in ipairs(char:GetDescendants()) do
                if v:IsA("Script") and (v.Name:lower():find("recoil") or v.Name:lower():find("spread")) then
                    v.Disabled = true
                end
            end
        end
    end)
end)

connections["Heartbeat"] = RunService.Heartbeat:Connect(function()
    pcall(function()
        -- God Mode
        if godModeEnabled then applyGodMode() end
        
        -- ESP Updates
        if espEnabled then updateEsp() end
        
        -- Rainbow Chams rotation
        if rainbowChamsEnabled and chamsEnabled then
            rainbowHue = (rainbowHue + 1) % 360
            local color = Color3.fromHSV(rainbowHue / 360, 1, 1)
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local hl = p.Character:FindFirstChild("CapyCham")
                    if hl and hl:IsA("Highlight") then
                        hl.FillColor = color
                    end
                end
            end
        end
        
        -- Anti Blind
        if antiBlindEnabled then
            if Lighting then
                for _, v in ipairs(Lighting:GetChildren()) do
                    if v:IsA("BlurEffect") or v:IsA("ColorCorrectionEffect") then v.Enabled = false end
                end
            end
            local pg = LocalPlayer:FindFirstChild("PlayerGui")
            if pg then
                for _, v in ipairs(pg:GetDescendants()) do
                    if v:IsA("Frame") and v.Visible and (v.BackgroundColor3 == Color3.fromRGB(0,0,0) or v.BackgroundColor3 == Color3.fromRGB(255,255,255)) then
                        if v.Size.X.Scale >= 1 and v.Size.Y.Scale >= 1 and (v.Name:lower():find("blind") or v.Name:lower():find("fade") or v.Name:lower():find("black")) then
                            v.Visible = false
                        end
                    end
                end
            end
        end
        
        -- Local Character Visual Modifiers (Invisible, headless, limb remover)
        if localInvisible then
            local char = LocalPlayer.Character
            if char then
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        part.Transparency = 1
                        local dec = part:FindFirstChildOfClass("Decal")
                        if dec then dec.Enabled = false end
                    end
                end
            end
        elseif localTransparency > 0 then
            local char = LocalPlayer.Character
            if char then
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        part.LocalTransparencyModifier = localTransparency
                    end
                end
            end
        end
        
        if headlessEnabled then
            local char = LocalPlayer.Character
            local head = char and char:FindFirstChild("Head")
            if head then
                head.Transparency = 1
                local face = head:FindFirstChildOfClass("Decal")
                if face then face.Enabled = false end
            end
        end
        
        if noLimbsEnabled then
            local char = LocalPlayer.Character
            if char then
                for _, part in ipairs(char:GetChildren()) do
                    if part:IsA("BasePart") and (part.Name:find("Arm") or part.Name:find("Leg") or part.Name:find("Hand") or part.Name:find("Foot")) then
                        part.Transparency = 1
                    end
                end
            end
        end
    end)
end)

