-- Tracers (Laser Beams) ESP
local function attachTracerToPlayer(p)
    if not p or p == LocalPlayer or not tracerEspEnabled then return end
    if espTeamCheck and LocalPlayer.Team and p.Team and LocalPlayer.Team == p.Team then return end
    local char = p.Character
    local root = char and char:WaitForChild("HumanoidRootPart", 5)
    local localRoot = getRootPart(LocalPlayer)
    if not root or not localRoot then return end
    
    local targetAttach = root:FindFirstChild("CapyTracerAttach")
    if not targetAttach then
        targetAttach = Instance.new("Attachment")
        targetAttach.Name = "CapyTracerAttach"
        targetAttach.Parent = root
    end
    
    local localAttach = localRoot:FindFirstChild("CapyTracerLocalAttach")
    if not localAttach then
        localAttach = Instance.new("Attachment")
        localAttach.Name = "CapyTracerLocalAttach"
        localAttach.Parent = localRoot
    end
    
    local beam = char:FindFirstChild("CapyTracer")
    if not beam then
        beam = Instance.new("Beam")
        beam.Name = "CapyTracer"
        beam.Width0 = 0.12
        beam.Width1 = 0.12
        beam.FaceCamera = true
        beam.Color = ColorSequence.new(C.accent)
        beam.Parent = char
    end
    beam.Attachment0 = localAttach
    beam.Attachment1 = targetAttach
end

local function removeTracer(p)
    local char = p and p.Character
    if char then
        local beam = char:FindFirstChild("CapyTracer")
        if beam then pcall(function() beam:Destroy() end) end
        local root = char:FindFirstChild("HumanoidRootPart")
        local attach = root and root:FindFirstChild("CapyTracerAttach")
        if attach then pcall(function() attach:Destroy() end) end
    end
end

local function toggleTracerEsp(e)
    tracerEspEnabled = e
    if e then
        for _, p in ipairs(Players:GetPlayers()) do
            attachTracerToPlayer(p)
        end
    else
        for _, p in ipairs(Players:GetPlayers()) do
            removeTracer(p)
        end
        local localRoot = getRootPart(LocalPlayer)
        local attach = localRoot and localRoot:FindFirstChild("CapyTracerLocalAttach")
        if attach then pcall(function() attach:Destroy() end) end
    end
end

