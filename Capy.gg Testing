local function updateEsp()
    local localRoot = getRootPart(LocalPlayer)
    for p, bb in pairs(espMap) do
        if bb and bb.Parent and p.Character then
            local root = getRootPart(p)
            local hum = getHumanoid(p)
            if root and localRoot and hum then
                local dist = math.round((root.Position - localRoot.Position).Magnitude)
                local hp = math.round(hum.Health)
                local maxHp = math.round(hum.MaxHealth)
                local hpPct = maxHp > 0 and math.round((hp / maxHp) * 100) or 0
                
                local lbl = bb:FindFirstChildOfClass("TextLabel")
                if lbl then
                    lbl.Text = string.format("%s\n[%s studs] [%s%% HP]", p.DisplayName or p.Name, dist, hpPct)
                    if hpPct > 50 then
                        lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
                    elseif hpPct > 20 then
                        lbl.TextColor3 = Color3.fromRGB(251, 191, 36)
                    else
                        lbl.TextColor3 = Color3.fromRGB(239, 68, 68)
                    end
                end
            end
        else
            espMap[p] = nil
        end
    end
end

