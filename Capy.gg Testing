                        grabBodyPos.Position = root.Position
                        grabBodyPos.Parent = root
                    end
                end)
                notify("Trolling", "Grabbing " .. player.Name .. "! Click again to release.", 2)
            end
        elseif grabbedPlayer then
            releaseGrabbedPlayer()
            notify("Trolling", "Released player.", 2)
        end
    end
end)

