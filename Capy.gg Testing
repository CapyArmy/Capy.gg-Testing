                dropFrame.Visible = false
                pcall(cb, opt)
            end)
            
            ob.MouseEnter:Connect(function()
                ob.BackgroundColor3 = C.accentH
            end)
            ob.MouseLeave:Connect(function()
                ob.BackgroundColor3 = C.surface
            end)
        end
        
        btn.MouseButton1Click:Connect(function()
            dropFrame.Visible = not dropFrame.Visible
            if dropFrame.Visible then
                local absPos = btn.AbsolutePosition
                local winPos = win.AbsolutePosition
                dropFrame.Position = UDim2.new(0, absPos.X - winPos.X - 10, 0, absPos.Y - winPos.Y + 26)
            end
        end)
        
        UserInputService.InputBegan:Connect(function(input, proc)
            if proc then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                task.wait()
                local obj = input.Target
                local inDropdown = false
                local function check(p)
                    if not p then return end
                    if p == dropFrame or p == btn then inDropdown = true; return end
                    check(p.Parent)
                end
                check(obj)
                if not inDropdown then
                    dropFrame.Visible = false
                end
            end
        end)
    end
    
