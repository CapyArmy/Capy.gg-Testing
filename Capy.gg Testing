            task.spawn(function()
                while _G.capyFlingAllActive do
                    pcall(function()
                        local char = LocalPlayer.Character
                        local root = getRootPart(LocalPlayer)
                        local hum = getHumanoid(LocalPlayer)
                        if not char or not root or not hum then return end
                        setNoclip(true)
                        for _, child in pairs(char:GetDescendants()) do
                            if child:IsA("BasePart") then
                                child.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5)
                                child.CanCollide = false
                                child.Massless = true
                            end
                        end
                    end)
                    local targets = {}
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= LocalPlayer and getRootPart(p) then
                            targets[#targets+1] = p
                        end
                    end
                    for _, target in ipairs(targets) do
                        if not _G.capyFlingAllActive then break end
                        local tr = getRootPart(target)
                        if tr then
                            local startPos = tr.Position
                            local myRoot = getRootPart(LocalPlayer)
                            if myRoot then
                                myRoot.CFrame = CFrame.new(startPos + Vector3.new(0, 3, 0))
                                if not tr:FindFirstChild("CapyFlingAV") then
                                    local av = Instance.new("BodyAngularVelocity")
                                    av.Name = "CapyFlingAV"
                                    av.AngularVelocity = Vector3.new(0, 99999, 0)
                                    av.MaxTorque = Vector3.new(0, math.huge, 0)
                                    av.P = math.huge
                                    av.Parent = tr
                                end
                            end
                            local timeout = 0
                            local flung = false
                            while timeout < 30 and not flung and _G.capyFlingAllActive do
                                task.wait(0.1)
                                timeout = timeout + 1
                                if tr and tr.Parent then
                                    local vel = tr.Velocity.Magnitude
                                    if vel > 50 then
                                        flung = true
                                    end
                                end
                            end
                        end
                        task.wait(0.2)
                    end
                    task.wait(1)
                end
                flingEnabled = false
                setNoclip(false)
                pcall(function()
                    local char = LocalPlayer.Character
                    if flingBodyAV and flingBodyAV.Parent then flingBodyAV:Destroy() end
                    flingBodyAV = nil
