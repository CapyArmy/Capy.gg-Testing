-- Walk Fling loop (velocity multiplication, event-driven like IY)
task.spawn(function()
    local movel = 0.1
    while true do
        if walkflingEnabled then
            RunService.Heartbeat:Wait()
            if walkflingEnabled then
                local vel
                pcall(function()
                    local root = getRootPart(LocalPlayer)
                    local char = getCharacter(LocalPlayer)
                    if char and root then
                        vel = root.Velocity
                        root.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)
                    end
                end)
                RunService.RenderStepped:Wait()
                if walkflingEnabled then
                    if vel then
                        pcall(function()
                            local root = getRootPart(LocalPlayer)
                            local char = getCharacter(LocalPlayer)
                            if char and root then
                                root.Velocity = vel
                            end
                        end)
                    end
                    RunService.Stepped:Wait()
                    if walkflingEnabled then
                        pcall(function()
                            local root = getRootPart(LocalPlayer)
                            local char = getCharacter(LocalPlayer)
                            if char and root and vel then
                                root.Velocity = vel + Vector3.new(0, movel, 0)
                                movel = movel * -1
                            end
                        end)
                    else
                        pcall(function()
                            local r = getRootPart(LocalPlayer)
                            if r then r.Velocity = Vector3.new(0,0,0) end
                        end)
                    end
                else
                    pcall(function()
                        local r = getRootPart(LocalPlayer)
                        if r then r.Velocity = Vector3.new(0,0,0) end
                    end)
                end
            else
                movel = 0.1
                task.wait(0.3)
            end
        else
            movel = 0.1
            task.wait(0.3)
        end
    end
end)

