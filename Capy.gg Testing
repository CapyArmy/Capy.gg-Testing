local function saveSettings()
    local http = game:GetService("HttpService")
    local data = {}
    for k, v in pairs(settingsMap) do
        data[k] = v.g()
    end
    local json = http:JSONEncode(data)
    local ok, func = pcall(function() return type(writefile) end)
    if ok and func == "function" then
        pcall(writefile, SAVE_FILE, json)
    end
end

local function loadSettings()
    local ok, func = pcall(function() return type(readfile) end)
    if not (ok and func == "function") then return end
    local ok, data = pcall(readfile, SAVE_FILE)
    if not (ok and data and #data > 0) then return end
    local http = game:GetService("HttpService")
    local ok, decoded = pcall(function() return http:JSONDecode(data) end)
    if not ok or type(decoded) ~= "table" then return end
    for k, v in pairs(decoded) do
        if settingsMap[k] and settingsMap[k].s then
            settingsMap[k].s(v)
        end
    end
end

