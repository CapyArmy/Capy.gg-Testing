local function applyNoclip()
    local char = LocalPlayer and LocalPlayer.Character
    if not char then return end
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("BasePart") then
            v.CanCollide = false
        end
    end
end

local function restoreNoclip()
    local char = LocalPlayer and LocalPlayer.Character
    if not char then return end
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("BasePart") then
            v.CanCollide = true
        end
    end
end

local function setNoclip(v)
    noclipEnabled = v
    if v then
        applyNoclip()
    else
        restoreNoclip()
    end
 end

local godModeCon = nil
local godModeDiedCon = nil
local function applyGodMode()
    local char = LocalPlayer and LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    -- Health refill (always works)
    pcall(function() hum.Health = hum.MaxHealth end)
    pcall(function() hum.BreakJointsOnDeath = false end)
    
    -- Disable Dead state (may error on some executors, isolated)
    pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false) end)
    
    -- HealthChanged connection (one-time setup)
    if not godModeCon then
        pcall(function()
            godModeCon = hum.HealthChanged:Connect(function(hp)
                if godModeEnabled and hum and hp < 1 then
                    pcall(function() hum.Health = hum.MaxHealth end)
                end
            end)
        end)
    end
    
    -- Died connection (one-time setup)
    if not godModeDiedCon then
        pcall(function()
            godModeDiedCon = hum.Died:Connect(function()
                if godModeEnabled and LocalPlayer.Character == char then
                    task.wait(0.5)
                    pcall(function()
                        char:BreakJoints()
                        task.wait(1)
                        local nh = char:FindFirstChildOfClass("Humanoid")
                        if nh then nh.Health = nh.MaxHealth end
                    end)
                end
            end)
        end)
    end
    
    -- ForceField (re-created every tick to beat anti-forcefield scripts)
    pcall(function()
        local old = char:FindFirstChild("CapyGodForce")
        if old then old:Destroy() end
        local ff = Instance.new("ForceField")
        ff.Name = "CapyGodForce"
        ff.Visible = false
        ff.Parent = char
    end)
    
    -- Block damage remotes
    pcall(function()
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
                local name = v.Name:lower()
                if name:find("damage") or name:find("hit") or name:find("take") or name:find("bullet") or name:find("melee") or name:find("attack") or name:find("hurt") or name:find("kill") then
                    pcall(function() v:FireServer(0) end)
                end
            end
        end
    end)
end

local function restoreGodMode()
    pcall(function()
        local char = LocalPlayer and LocalPlayer.Character
        if char then
            pcall(function()
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then
                    hum.BreakJointsOnDeath = true
                    pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true) end)
                end
            end)
            pcall(function()
                local ff = char:FindFirstChild("CapyGodForce")
                if ff then ff:Destroy() end
            end)
        end
        if godModeCon then pcall(function() godModeCon:Disconnect() end); godModeCon = nil end
        if godModeDiedCon then pcall(function() godModeDiedCon:Disconnect() end); godModeDiedCon = nil end
    end)
end

local function setGodMode(v)
    godModeEnabled = v
    if v then
        applyGodMode()
    else
        restoreGodMode()
    end
end

local function safeHttpGet(url)
    if type(game.HttpGet) == "function" then
        local ok, r = pcall(function() return game:HttpGet(url) end)
        if ok and r then return r end
    end
    if type(syn) == "table" and type(syn.request) == "function" then
        local ok, r = pcall(function() return syn.request({Url = url, Method = "GET"}) end)
        if ok and r and r.Body then return r.Body end
    end
    if type(http) == "table" and type(http.request) == "function" then
        local ok, r = pcall(function() return http.request({Url = url, Method = "GET"}) end)
        if ok and r and r.Body then return r.Body end
    end
    if type(http_request) == "function" then
        local ok, r = pcall(function() return http_request({Url = url, Method = "GET"}) end)
        if ok and r and r.Body then return r.Body end
    end
    return nil
end

